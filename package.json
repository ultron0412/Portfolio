{
  "name": "my-portfolio-showcase",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:client:dev\" \"npm:server:dev\"",
    "client:dev": "vite dev",
    "server:dev": "node --watch server/src/server.js",
    "server:start": "node server/src/server.js",
